<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>net.rsworld</groupId>
  <artifactId>superduper-parent</artifactId>
  <version>0.6.5-SNAPSHOT</version>
  <packaging>pom</packaging>
  <name>SUPERDUPER</name>
  <description>Resilient, ordered, database-backed Kafka consumption pattern with pluggable workers.</description>
  <url>https://github.com/riadshalaby/superduper</url>
  <inceptionYear>2026</inceptionYear>

  <organization>
    <name>RSWorld</name>
    <url>https://rsworld.eu</url>
  </organization>

  <licenses>
    <license>
      <name>MIT License</name>
      <url>http://www.opensource.org/licenses/mit-license.php</url>
    </license>
  </licenses>

  <developers>
    <developer>
      <id>riadshalaby</id>
      <name>Riad Shalaby</name>
      <email>riad@rsworld.eu</email>
      <organization>RSWorld</organization>
      <organizationUrl>https://rsworld.eu</organizationUrl>
    </developer>
  </developers>

  <modules>
    <module>observability-api</module>
    <module>observability-logging</module>
    <module>observability-metrics</module>
    <module>repository-api</module>
    <module>repository-jdbc</module>
    <module>repository-r2dbc</module>
    <module>worker-blocking</module>
    <module>worker-reactive</module>
    <module>consumer-kafka-blocking</module>
    <module>consumer-kafka-reactive</module>
    <module>starter-autoselect</module>
    <module>coverage-report</module>
    <module>schema-liquibase</module>
    <module>examples/app-blocking</module>
    <module>examples/app-multitopic-dedicated</module>
    <module>examples/app-multitopic-shared</module>
    <module>examples/app-reactive</module>
    <module>examples/seeder</module>
  </modules>

  <scm>
    <connection>scm:git:git://github.com/riadshalaby/superduper.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/riadshalaby/superduper.git</developerConnection>
    <url>https://github.com/riadshalaby/superduper</url>
  </scm>

  <distributionManagement>
    <repository>
      <id>central</id>
      <url>https://central.sonatype.com/api/v1/publisher</url>
    </repository>
  </distributionManagement>

  <properties>
    <java.version>25</java.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    <maven.compiler.source>${java.version}</maven.compiler.source>
    <maven.compiler.target>${java.version}</maven.compiler.target>
    <spring-boot.version>4.0.2</spring-boot.version>
    <r2dbc-postgres.version>1.1.1.RELEASE</r2dbc-postgres.version>
    <shedlock.version>7.6.0</shedlock.version>
    <junit.version>6.0.2</junit.version>
    <mockito.version>5.21.0</mockito.version>
    <assertj.version>4.0.0-M1</assertj.version>
    <byte-buddy.version>1.18.4</byte-buddy.version>
    <jacoco.version>0.8.14</jacoco.version>
    <jacoco.check.skip>false</jacoco.check.skip>
    <jacoco.aggregate.minimum.line.coverage>0.80</jacoco.aggregate.minimum.line.coverage>
    <jacoco.module.minimum.line.coverage>0.70</jacoco.module.minimum.line.coverage>
    <postgresql.version>42.7.10</postgresql.version>
    <reactor-core.version>3.8.3</reactor-core.version>
    <maven-source-plugin.version>3.3.1</maven-source-plugin.version>
    <maven-javadoc-plugin.version>3.12.0</maven-javadoc-plugin.version>
    <maven-gpg-plugin.version>3.2.8</maven-gpg-plugin.version>
    <central-publishing-maven-plugin.version>0.9.0</central-publishing-maven-plugin.version>
    <sonar-maven-plugin.version>5.5.0.6356</sonar-maven-plugin.version>
    <sonar.organization>rsworld</sonar.organization>
    <sonar.host.url>https://sonarcloud.io</sonar.host.url>
    <sonar.projectKey>rsworld_superduper</sonar.projectKey>
    <sonar.java.coveragePlugin>jacoco</sonar.java.coveragePlugin>
    <sonar.coverage.jacoco.xmlReportPaths>coverage-report/target/site/jacoco-aggregate/jacoco.xml,**/target/site/jacoco/jacoco.xml</sonar.coverage.jacoco.xmlReportPaths>
    <sonar.exclusions>**/src/test/**</sonar.exclusions>
    <central.skipPublishing>false</central.skipPublishing>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-api</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-logging</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-metrics</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-api</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-jdbc</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-r2dbc</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-worker-blocking</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-worker-reactive</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-consumer-kafka-blocking</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-consumer-kafka-reactive</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-starter-autoselect</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-schema-liquibase</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-schema-liquibase</artifactId>
        <version>${project.version}</version>
        <type>test-jar</type>
      </dependency>
      <dependency>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-dependencies</artifactId>
        <version>${spring-boot.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>org.junit.jupiter</groupId>
        <artifactId>junit-jupiter</artifactId>
        <version>${junit.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-core</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.assertj</groupId>
        <artifactId>assertj-core</artifactId>
        <version>${assertj.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.postgresql</groupId>
        <artifactId>postgresql</artifactId>
        <version>${postgresql.version}</version>
      </dependency>
      <dependency>
        <groupId>io.projectreactor</groupId>
        <artifactId>reactor-core</artifactId>
        <version>${reactor-core.version}</version>
      </dependency>
      <dependency>
        <groupId>io.projectreactor</groupId>
        <artifactId>reactor-test</artifactId>
        <version>${reactor-core.version}</version>
        <scope>test</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>net.bytebuddy</groupId>
      <artifactId>byte-buddy-agent</artifactId>
      <version>${byte-buddy.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>versions-maven-plugin</artifactId>
          <version>2.21.0</version>
        </plugin>
        <plugin>
          <groupId>com.diffplug.spotless</groupId>
          <artifactId>spotless-maven-plugin</artifactId>
          <version>3.2.1</version>
          <configuration>
            <java>
              <palantirJavaFormat>
                <version>2.78.0</version>
                <formatJavadoc>true</formatJavadoc>
              </palantirJavaFormat>

              <removeUnusedImports/>
              <trimTrailingWhitespace/>
              <endWithNewline/>
              <formatAnnotations/>
            </java>
            <pom>
              <sortPom/>
            </pom>
          </configuration>
          <executions>
            <!-- In CI wollen wir failen, wenn Format nicht passt -->
            <execution>
              <id>spotless-check</id>
              <goals>
                <goal>check</goal>
              </goals>
              <phase>verify</phase>
            </execution>
            <!-- lokales Auto-Fix optional als eigenes Execution/Profil -->
            <!-- mvn -Pspotless-apply verify -->
          </executions>
        </plugin>
        <plugin>
          <groupId>org.springframework.boot</groupId>
          <artifactId>spring-boot-maven-plugin</artifactId>
          <version>${spring-boot.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.15.0</version>
          <configuration>
            <source>${java.version}</source>
            <target>${java.version}</target>
            <parameters>true</parameters>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>3.5.4</version>
          <configuration>
            <useModulePath>false</useModulePath>
            <argLine>${argLine} -Xshare:off -javaagent:${settings.localRepository}/net/bytebuddy/byte-buddy-agent/${byte-buddy.version}/byte-buddy-agent-${byte-buddy.version}.jar
              -XX:+EnableDynamicAgentLoading</argLine>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.jacoco</groupId>
          <artifactId>jacoco-maven-plugin</artifactId>
          <version>${jacoco.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-jar-plugin</artifactId>
          <version>3.4.2</version>
        </plugin>
        <plugin>
          <groupId>org.sonarsource.scanner.maven</groupId>
          <artifactId>sonar-maven-plugin</artifactId>
          <version>${sonar-maven-plugin.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-source-plugin</artifactId>
          <version>${maven-source-plugin.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-javadoc-plugin</artifactId>
          <version>${maven-javadoc-plugin.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-gpg-plugin</artifactId>
          <version>${maven-gpg-plugin.version}</version>
        </plugin>
        <plugin>
          <groupId>org.sonatype.central</groupId>
          <artifactId>central-publishing-maven-plugin</artifactId>
          <version>${central-publishing-maven-plugin.version}</version>
        </plugin>
      </plugins>
    </pluginManagement>

    <plugins>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <executions>
          <execution>
            <id>prepare-agent</id>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>report</id>
            <goals>
              <goal>report</goal>
            </goals>
            <phase>verify</phase>
          </execution>
          <execution>
            <id>check-module-coverage</id>
            <goals>
              <goal>check</goal>
            </goals>
            <phase>verify</phase>
            <configuration>
              <skip>${jacoco.check.skip}</skip>
              <rules>
                <rule>
                  <element>BUNDLE</element>
                  <limits>
                    <limit>
                      <counter>LINE</counter>
                      <value>COVEREDRATIO</value>
                      <minimum>${jacoco.module.minimum.line.coverage}</minimum>
                    </limit>
                  </limits>
                </rule>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>com.diffplug.spotless</groupId>
        <artifactId>spotless-maven-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>org.sonarsource.scanner.maven</groupId>
        <artifactId>sonar-maven-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>3.6.2</version>
        <executions>
          <execution>
            <id>enforce-versions</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <phase>compile</phase>
            <configuration>
              <rules>
                <!-- Minimum Maven version -->
                <requireMavenVersion>
                  <version>[3.9,)</version>
                </requireMavenVersion>
                <!-- Optional but strongly recommended: minimum Java version -->
                <requireJavaVersion>
                  <version>[21,)</version>
                </requireJavaVersion>
              </rules>
              <fail>true</fail>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <profile>
      <id>release</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-source-plugin</artifactId>
            <executions>
              <execution>
                <id>attach-sources</id>
                <goals>
                  <goal>jar-no-fork</goal>
                </goals>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-javadoc-plugin</artifactId>
            <configuration>
              <doclint>none</doclint>
              <quiet>true</quiet>
            </configuration>
            <executions>
              <execution>
                <id>attach-javadocs</id>
                <goals>
                  <goal>jar</goal>
                </goals>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-gpg-plugin</artifactId>
            <configuration>
              <bestPractices>true</bestPractices>
              <signer>bc</signer>
              <keyEnvName>MAVEN_GPG_KEY</keyEnvName>
              <passphraseEnvName>MAVEN_GPG_PASSPHRASE</passphraseEnvName>
              <skip>${gpg.skip}</skip>
            </configuration>
            <executions>
              <execution>
                <id>sign-artifacts</id>
                <goals>
                  <goal>sign</goal>
                </goals>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.sonatype.central</groupId>
            <artifactId>central-publishing-maven-plugin</artifactId>
            <extensions>true</extensions>
            <configuration>
              <publishingServerId>central</publishingServerId>
              <autoPublish>true</autoPublish>
              <waitUntil>published</waitUntil>
              <checksums>required</checksums>
              <skipPublishing>${central.skipPublishing}</skipPublishing>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
