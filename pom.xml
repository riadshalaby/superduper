<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>net.rsworld</groupId>
  <artifactId>superduper-parent</artifactId>
  <version>0.5.0</version>
  <packaging>pom</packaging>

  <modules>
    <module>observability-api</module>
    <module>observability-logging</module>
    <module>observability-metrics</module>
    <module>repository-api</module>
    <module>repository-jdbc</module>
    <module>repository-r2dbc</module>
    <module>worker-blocking</module>
    <module>worker-reactive</module>
    <module>consumer-kafka-blocking</module>
    <module>consumer-kafka-reactive</module>
    <module>starter-autoselect</module>
    <module>schema-liquibase</module>
    <module>examples/app-blocking</module>
    <module>examples/app-reactive</module>
    <module>examples/seeder</module>
  </modules>

  <properties>
    <java.version>25</java.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    <maven.compiler.source>${java.version}</maven.compiler.source>
    <maven.compiler.target>${java.version}</maven.compiler.target>
    <spring-boot.version>4.0.2</spring-boot.version>
    <r2dbc-postgres.version>1.1.1.RELEASE</r2dbc-postgres.version>
    <shedlock.version>7.6.0</shedlock.version>
    <junit.version>6.0.2</junit.version>
    <mockito.version>5.21.0</mockito.version>
    <assertj.version>4.0.0-M1</assertj.version>
    <byte-buddy.version>1.18.4</byte-buddy.version>
    <jacoco.version>0.8.14</jacoco.version>
    <postgresql.version>42.7.10</postgresql.version>
    <reactor-core.version>3.8.3</reactor-core.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-api</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-logging</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-observability-metrics</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-api</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-jdbc</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-repository-r2dbc</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-worker-blocking</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-worker-reactive</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-consumer-kafka-blocking</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-consumer-kafka-reactive</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-starter-autoselect</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-schema-liquibase</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>net.rsworld</groupId>
        <artifactId>superduper-schema-liquibase</artifactId>
        <version>${project.version}</version>
        <type>test-jar</type>
      </dependency>
      <dependency>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-dependencies</artifactId>
        <version>${spring-boot.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>org.junit.jupiter</groupId>
        <artifactId>junit-jupiter</artifactId>
        <version>${junit.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.mockito</groupId>
        <artifactId>mockito-core</artifactId>
        <version>${mockito.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.assertj</groupId>
        <artifactId>assertj-core</artifactId>
        <version>${assertj.version}</version>
        <scope>test</scope>
      </dependency>
      <dependency>
        <groupId>org.postgresql</groupId>
        <artifactId>postgresql</artifactId>
        <version>${postgresql.version}</version>
      </dependency>
      <dependency>
        <groupId>io.projectreactor</groupId>
        <artifactId>reactor-core</artifactId>
        <version>${reactor-core.version}</version>
      </dependency>
      <dependency>
        <groupId>io.projectreactor</groupId>
        <artifactId>reactor-test</artifactId>
        <version>${reactor-core.version}</version>
        <scope>test</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>versions-maven-plugin</artifactId>
          <version>2.21.0</version>
        </plugin>
        <plugin>
          <groupId>com.diffplug.spotless</groupId>
          <artifactId>spotless-maven-plugin</artifactId>
          <version>3.2.1</version>
          <configuration>
            <java>
              <palantirJavaFormat>
                <version>2.78.0</version>
                <formatJavadoc>true</formatJavadoc>
              </palantirJavaFormat>

              <removeUnusedImports/>
              <trimTrailingWhitespace/>
              <endWithNewline/>
              <formatAnnotations/>
            </java>
            <pom>
              <sortPom/>
            </pom>
          </configuration>
          <executions>
            <!-- In CI wollen wir failen, wenn Format nicht passt -->
            <execution>
              <id>spotless-check</id>
              <goals>
                <goal>check</goal>
              </goals>
              <phase>verify</phase>
            </execution>
            <!-- lokales Auto-Fix optional als eigenes Execution/Profil -->
            <!-- mvn -Pspotless-apply verify -->
          </executions>
        </plugin>
        <plugin>
          <groupId>org.springframework.boot</groupId>
          <artifactId>spring-boot-maven-plugin</artifactId>
          <version>${spring-boot.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.15.0</version>
          <configuration>
            <source>${java.version}</source>
            <target>${java.version}</target>
            <parameters>true</parameters>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>3.5.4</version>
          <configuration>
            <useModulePath>false</useModulePath>
            <argLine>${argLine} -Xshare:off -javaagent:${settings.localRepository}/net/bytebuddy/byte-buddy-agent/${byte-buddy.version}/byte-buddy-agent-${byte-buddy.version}.jar
              -XX:+EnableDynamicAgentLoading</argLine>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.jacoco</groupId>
          <artifactId>jacoco-maven-plugin</artifactId>
          <version>${jacoco.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-jar-plugin</artifactId>
          <version>3.4.2</version>
        </plugin>
      </plugins>
    </pluginManagement>

    <plugins>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <executions>
          <execution>
            <id>prepare-agent</id>
            <goals>
              <goal>prepare-agent</goal>
            </goals>
          </execution>
          <execution>
            <id>report</id>
            <goals>
              <goal>report</goal>
            </goals>
            <phase>verify</phase>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>com.diffplug.spotless</groupId>
        <artifactId>spotless-maven-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>3.6.2</version>
        <executions>
          <execution>
            <id>enforce-versions</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <phase>compile</phase>
            <configuration>
              <rules>
                <!-- Minimum Maven version -->
                <requireMavenVersion>
                  <version>[3.9,)</version>
                </requireMavenVersion>
                <!-- Optional but strongly recommended: minimum Java version -->
                <requireJavaVersion>
                  <version>[21,)</version>
                </requireJavaVersion>
              </rules>
              <fail>true</fail>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
